<?xml version="1.0" encoding="utf-8"?>
<!--
  Theme.Tvgram — base theme for the app.
  Compose for TV handles its own theming via tv-material; this XML
  theme is just the activity window backdrop during cold start.
-->
<resources>

    <style name="Theme.Tvgram" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
