<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml — Tvgram

  Notes:
  - Leanback launcher category (works on 国行 Bravia; no GMS required)
  - android.software.leanback feature is required (TV-only)
  - android.hardware.touchscreen NOT required (TV has no touch)
  - No INTERNET permission in manifest — TDLib uses its own network stack
    over MTProto (D-002)
  - UsesPermission for storage scoped to the app's private dir
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- TDLib needs INTERNET. Keep plain (no export cert pinning). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Leanback: TV is required, touchscreen NOT required -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".TgTvApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:banner="@drawable/tv_banner"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tvgram"
        android:usesCleartextTraffic="false"
        tools:targetApi="34">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Tvgram">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
